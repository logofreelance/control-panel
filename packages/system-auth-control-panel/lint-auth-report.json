ng generic type parameters that you don't need to know the type of."}]},{"ruleId":"no-restricted-syntax","severity":2,"message":"Hardcoded strings are STRICTLY FORBIDDEN in logic files. Use constants from src/config/labels.ts.","line":54,"column":41,"nodeType":"Literal","messageId":"restrictedSyntax","endLine":54,"endColumn":56},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":66,"column":55,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":66,"endColumn":58,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[2547,2550],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[2547,2550],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"no-restricted-syntax","severity":2,"message":"Hardcoded strings are STRICTLY FORBIDDEN in logic files. Use constants from src/config/labels.ts.","line":144,"column":45,"nodeType":"Literal","messageId":"restrictedSyntax","endLine":144,"endColumn":60},{"ruleId":"no-restricted-syntax","severity":2,"message":"Hardcoded strings are STRICTLY FORBIDDEN in logic files. Use constants from src/config/labels.ts.","line":169,"column":45,"nodeType":"Literal","messageId":"restrictedSyntax","endLine":169,"endColumn":60}],"suppressedMessages":[],"errorCount":6,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Context } from 'hono';\r\nimport { StatusCode } from 'hono/utils/http-status';\r\nimport { createDb } from '@modular/database';\r\nimport { AuthService } from '../services/auth';\r\nimport { AUTH_CONSTANTS } from '../config/constants';\r\nimport { AUTH_LABELS } from '../config/labels';\r\n\r\nimport { getEnv } from '@cp/config';\r\n\r\nconst SYS = AUTH_CONSTANTS;\r\nconst MSG = AUTH_LABELS.messages;\r\n\r\nconst response = (c: Context, status: typeof SYS.STATUS.SUCCESS | typeof SYS.STATUS.ERROR, data: unknown = null, message?: string, code: number = SYS.HTTP_CODE.OK) => {\r\n    return c.json({\r\n        status,\r\n        data,\r\n        message,\r\n        timestamp: new Date().toISOString(),\r\n    }, code as any);\r\n};\r\n\r\nexport const AuthHonoHandlers = {\r\n    /**\r\n     * POST /login\r\n     * Admin Login\r\n     */\r\n    login: async (c: Context) => {\r\n        try {\r\n            const { username, password } = await c.req.json();\r\n\r\n            const env = getEnv(c);\r\n            const dbUrl = env[SYS.ENV_KEYS.DATABASE_URL];\r\n            const jwtSecret = env[SYS.ENV_KEYS.JWT_SECRET];\r\n\r\n            if (!dbUrl) return response(c, SYS.STATUS.ERROR, null, SYS.ERRORS.DB_URL_MISSING, SYS.HTTP_CODE.INTERNAL_ERROR);\r\n            if (!jwtSecret) return response(c, SYS.STATUS.ERROR, null, SYS.ERRORS.JWT_SECRET_MISSING, SYS.HTTP_CODE.INTERNAL_ERROR);\r\n\r\n            const db = createDb(dbUrl);\r\n            const service = new AuthService(db, jwtSecret);\r\n            const result = await service.adminLogin(username, password);\r\n\r\n            return response(c, SYS.STATUS.SUCCESS, result);\r\n        } catch (err: unknown) {\r\n            const msg = err instanceof Error ? err.message : String(err);\r\n            const code = msg === MSG.invalidCredentials ? SYS.HTTP_CODE.UNAUTHORIZED : SYS.HTTP_CODE.INTERNAL_ERROR;\r\n            return response(c, SYS.STATUS.ERROR, null, msg, code as number);\r\n        }\r\n    },\r\n\r\n    /**\r\n     * Helper to verify token and get Admin ID\r\n     */\r\n    verifyRequest: (c: Context) => {\r\n        const authHeader = c.req.header('Authorization');\r\n        if (!authHeader || !authHeader.startsWith(SYS.TOKEN.PREFIX)) {\r\n            throw new Error(MSG.noTokenProvided);\r\n        }\r\n        const token = authHeader.split(SYS.TOKEN.SEPARATOR)[1];\r\n\r\n        const env = getEnv(c);\r\n        const jwtSecret = env[SYS.ENV_KEYS.JWT_SECRET];\r\n\r\n        if (!jwtSecret) throw new Error(SYS.ERRORS.JWT_SECRET_MISSING);\r\n\r\n        const service = new AuthService(null, jwtSecret);\r\n        const payload = service.verifyToken(token) as any; // Cast as any to access custom fields safely\r\n\r\n        // Ensure payload has ID\r\n        if (!payload || !payload.id) throw new Error(MSG.tokenInvalid);\r\n        return {\r\n            id: payload.id as number,\r\n            dbUrl: env[SYS.ENV_KEYS.DATABASE_URL],\r\n            jwtSecret\r\n        };\r\n    },\r\n\r\n    /**\r\n     * POST /update-profile\r\n     * Update Admin Profile (Username)\r\n     * SECURED: Requires Token\r\n     */\r\n    updateProfile: async (c: Context) => {\r\n        try {\r\n            // 1. Verify Token & Get ID\r\n            const { id, dbUrl, jwtSecret } = AuthHonoHandlers.verifyRequest(c);\r\n            if (!dbUrl) throw new Error(SYS.ERRORS.DB_URL_MISSING);\r\n\r\n            // 2. Parse Body\r\n            const { newUsername } = await c.req.json();\r\n\r\n            // 3. Call Service\r\n            const db = createDb(dbUrl);\r\n            const service = new AuthService(db, jwtSecret);\r\n            const result = await service.updateAdminProfile(id, newUsername);\r\n\r\n            // 4. Return Mature Data\r\n            return response(c, SYS.STATUS.SUCCESS, null, result.message);\r\n        } catch (err: unknown) {\r\n            const msg = err instanceof Error ? err.message : String(err);\r\n            let code: number = SYS.HTTP_CODE.INTERNAL_ERROR;\r\n            if (msg === MSG.noTokenProvided || msg === MSG.tokenInvalid) code = SYS.HTTP_CODE.UNAUTHORIZED;\r\n            if (msg === MSG.adminNotFound) code = SYS.HTTP_CODE.NOT_FOUND;\r\n\r\n            return response(c, SYS.STATUS.ERROR, null, msg, code as number);\r\n        }\r\n    },\r\n\r\n    /**\r\n     * POST /change-password\r\n     * Change Admin Password\r\n     * SECURED: Requires Token\r\n     */\r\n    changePassword: async (c: Context) => {\r\n        try {\r\n            // 1. Verify Token & Get ID\r\n            const { id, dbUrl, jwtSecret } = AuthHonoHandlers.verifyRequest(c);\r\n            if (!dbUrl) throw new Error(SYS.ERRORS.DB_URL_MISSING);\r\n\r\n            // 2. Parse Body\r\n            const { currentPassword, newPassword } = await c.req.json();\r\n\r\n            // 3. Call Service\r\n            const db = createDb(dbUrl);\r\n            const service = new AuthService(db, jwtSecret);\r\n            const result = await service.changeAdminPassword(id, currentPassword, newPassword);\r\n\r\n            // 4. Return Mature Data\r\n            return response(c, SYS.STATUS.SUCCESS, null, result.message);\r\n        } catch (err: unknown) {\r\n            const msg = err instanceof Error ? err.message : String(err);\r\n            let code: number = SYS.HTTP_CODE.INTERNAL_ERROR;\r\n            if (msg === MSG.noTokenProvided || msg === MSG.tokenInvalid || msg === MSG.wrongPassword) code = SYS.HTTP_CODE.UNAUTHORIZED;\r\n            if (msg === MSG.adminNotFound) code = SYS.HTTP_CODE.NOT_FOUND;\r\n\r\n            return response(c, SYS.STATUS.ERROR, null, msg, code as number);\r\n        }\r\n    },\r\n\r\n    /**\r\n     * GET /verify-token\r\n     */\r\n    verifyToken: async (c: Context) => {\r\n        try {\r\n            const authHeader = c.req.header('Authorization');\r\n            if (!authHeader || !authHeader.startsWith(SYS.TOKEN.PREFIX)) {\r\n                return response(c, SYS.STATUS.ERROR, null, MSG.noTokenProvided, SYS.HTTP_CODE.UNAUTHORIZED);\r\n            }\r\n            const token = authHeader.split(SYS.TOKEN.SEPARATOR)[1];\r\n\r\n            const env = getEnv(c);\r\n            const jwtSecret = env[SYS.ENV_KEYS.JWT_SECRET];\r\n\r\n            if (!jwtSecret) return response(c, SYS.STATUS.ERROR, null, SYS.ERRORS.JWT_SECRET_MISSING, SYS.HTTP_CODE.INTERNAL_ERROR);\r\n\r\n            const service = new AuthService(null, jwtSecret); // No DB needed\r\n            const result = service.verifyToken(token);\r\n\r\n            return response(c, SYS.STATUS.SUCCESS, result);\r\n        } catch {\r\n            return response(c, SYS.STATUS.ERROR, null, MSG.tokenInvalid, SYS.HTTP_CODE.UNAUTHORIZED);\r\n        }\r\n    },\r\n\r\n    /**\r\n     * GET /me\r\n     */\r\n    getCurrentUser: async (c: Context) => {\r\n        try {\r\n            const authHeader = c.req.header('Authorization');\r\n            if (!authHeader || !authHeader.startsWith(SYS.TOKEN.PREFIX)) {\r\n                return response(c, SYS.STATUS.ERROR, null, MSG.noTokenProvided, SYS.HTTP_CODE.UNAUTHORIZED);\r\n            }\r\n            const token = authHeader.split(SYS.TOKEN.SEPARATOR)[1];\r\n\r\n            const env = getEnv(c);\r\n            const jwtSecret = env[SYS.ENV_KEYS.JWT_SECRET];\r\n\r\n            if (!jwtSecret) return response(c, SYS.STATUS.ERROR, null, SYS.ERRORS.JWT_SECRET_MISSING, SYS.HTTP_CODE.INTERNAL_ERROR);\r\n\r\n            const service = new AuthService(null, jwtSecret);\r\n            const result = service.decodeUser(token);\r\n\r\n            return response(c, SYS.STATUS.SUCCESS, result);\r\n        } catch {\r\n            return response(c, SYS.STATUS.ERROR, null, MSG.tokenInvalid, SYS.HTTP_CODE.UNAUTHORIZED);\r\n        }\r\n    },\r\n\r\n    /**\r\n     * POST /logout\r\n     */\r\n    logout: async (c: Context) => {\r\n        return response(c, SYS.STATUS.SUCCESS, null, MSG.loggedOut);\r\n    }\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\6 WEBSITE\\2 2025\\desember\\modularengine\\packages\\system-auth-control-panel\\src\\services\\auth.ts","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'sql' is defined but never used.","line":1,"column":14,"nodeType":null,"messageId":"unusedVar","endLine":1,"endColumn":17},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'result' is assigned a value but never used.","line":44,"column":15,"nodeType":null,"messageId":"unusedVar","endLine":44,"endColumn":21}],"suppressedMessages":[],"errorCount":2,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { eq, sql, createDb } from '@modular/database';\r\nimport { adminUsers } from '@modular/database';\r\nimport * as bcrypt from 'bcryptjs';\r\nimport * as jwt from 'jsonwebtoken';\r\nimport { AUTH_CONSTANTS } from '../config/constants';\r\nimport { AUTH_LABELS } from '../config/labels';\r\n\r\nconst SYS = AUTH_CONSTANTS;\r\nconst MSG = AUTH_LABELS.messages;\r\n\r\n// Type for DB instance (generic)\r\n// Type for DB instance (generic)\r\ntype DbInstance = ReturnType<typeof createDb>;\r\n\r\nexport class AuthService {\r\n    constructor(private db: DbInstance | null, private jwtSecret: string) {\r\n        if (!jwtSecret) throw new Error(SYS.ERRORS.JWT_SECRET_MISSING);\r\n    }\r\n\r\n    async adminLogin(username: string, password: string) {\r\n        if (!this.db) throw new Error(SYS.ERRORS.DB_URL_MISSING);\r\n        const admins = await this.db.select().from(adminUsers).where(eq(adminUsers.username, username)).limit(1);\r\n        const user = admins[0];\r\n\r\n        if (!user || !(await bcrypt.compare(password, user.passwordHash))) {\r\n            throw new Error(MSG.invalidCredentials);\r\n        }\r\n\r\n        const token = jwt.sign(\r\n            { id: user.id, username: user.username },\r\n            this.jwtSecret,\r\n            { expiresIn: SYS.JWT.ADMIN_EXPIRES_IN }\r\n        );\r\n\r\n        return { token };\r\n    }\r\n\r\n\r\n\r\n    async updateAdminProfile(id: number, newUsername: string) {\r\n        if (!this.db) throw new Error(SYS.ERRORS.DB_URL_MISSING);\r\n\r\n        // Update specific admin by ID\r\n        const result = await this.db.update(adminUsers)\r\n            .set({ username: newUsername })\r\n            .where(eq(adminUsers.id, id));\r\n\r\n        // Drizzle result check might vary by driver, but for now we assume success if no error thrown\r\n        // Standard Drizzle MySql2 result has 'affectedRows'\r\n        // But for generic usage, we can check if it exists first or just return success\r\n\r\n        return { message: MSG.profileUpdated };\r\n    }\r\n\r\n    async changeAdminPassword(id: number, currentPassword: string, newPassword: string) {\r\n        if (!this.db) throw new Error(SYS.ERRORS.DB_URL_MISSING);\r\n\r\n        // Verify current password for this specific user\r\n        const admins = await this.db.select().from(adminUsers).where(eq(adminUsers.id, id)).limit(1);\r\n        if (admins.length === 0) throw new Error(MSG.adminNotFound);\r\n\r\n        const admin = admins[0];\r\n        const limits = SYS.PASSWORD || { PASSWORD_MIN_LENGTH: 8 }; // Assuming SYS.PASSWORD has these limits\r\n\r\n        // Check password\r\n        const isMatch = await bcrypt.compare(currentPassword, admin.passwordHash);\r\n        if (!isMatch) throw new Error(MSG.wrongPassword);\r\n\r\n        // Validate new password\r\n        if (newPassword.length < limits.PASSWORD_MIN_LENGTH) {\r\n            throw new Error(MSG.passwordTooShort);\r\n        }\r\n\r\n        const newHash = await bcrypt.hash(newPassword, 10);\r\n\r\n        await this.db.update(adminUsers)\r\n            .set({ passwordHash: newHash })\r\n            .where(eq(adminUsers.id, id));\r\n\r\n        return { message: MSG.passwordChanged };\r\n    }\r\n\r\n    verifyToken(token: string) {\r\n        try {\r\n            const payload = jwt.verify(token, this.jwtSecret);\r\n            return { valid: true, payload };\r\n        } catch {\r\n            throw new Error(MSG.tokenInvalid);\r\n        }\r\n    }\r\n\r\n    // getCurrentUser is effectively verifyToken + returning consistent format. \r\n    // The handler does it. I'll keep logic here.\r\n    decodeUser(token: string) {\r\n        try {\r\n            // Define strict payload interface locally or via shared type if available\r\n            interface UserPayload {\r\n                id: number;\r\n                username: string;\r\n                email: string;\r\n                role: string;\r\n                permissions?: string[];\r\n            }\r\n\r\n            const payload = jwt.verify(token, this.jwtSecret) as UserPayload;\r\n            return {\r\n                id: payload.id,\r\n                username: payload.username,\r\n                email: payload.email,\r\n                role: payload.role,\r\n                permissions: payload.permissions || []\r\n            };\r\n        } catch {\r\n            throw new Error(MSG.tokenInvalid);\r\n        }\r\n    }\r\n}\r\n","usedDeprecatedRules":[]}]
